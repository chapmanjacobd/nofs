            cand -V 'Print version'
            cand --version 'Print version'
        }
        &'nofs;cp'= {
            cand --file-over-file 'File-over-file conflict strategy'
            cand --file-over-folder 'File-over-folder conflict strategy: skip, rename-src, rename-dest, delete-src, delete-dest, merge'
            cand --folder-over-file 'Folder-over-file conflict strategy: skip, rename-src, rename-dest, delete-src, delete-dest, merge'
            cand -j 'Number of parallel workers'
            cand --workers 'Number of parallel workers'
            cand -e 'Filter by file extensions (e.g., .mkv, .jpg)'
            cand --ext 'Filter by file extensions (e.g., .mkv, .jpg)'
            cand -E 'Exclude files matching glob pattern'
            cand --exclude 'Exclude files matching glob pattern'
            cand -I 'Include only files matching glob pattern'
            cand --include 'Include only files matching glob pattern'
            cand -S 'Filter by file size (e.g., +5M, -10M)'
            cand --size 'Filter by file size (e.g., +5M, -10M)'
            cand -l 'Limit number of files transferred'
            cand --limit 'Limit number of files transferred'
            cand --size-limit 'Limit total size transferred (e.g., 100M, 1G)'
            cand -c 'Path to configuration file'
            cand --config 'Path to configuration file'
            cand --policy 'Policy to use for branch selection'
            cand --minfreespace 'Minimum free space required on branch (e.g., "4G", "100M")'
            cand -n 'Simulate without making changes (dry-run)'
            cand --dry-run 'Simulate without making changes (dry-run)'
            cand -v 'Verbose output (print decision steps to stderr)'
            cand --verbose 'Verbose output (print decision steps to stderr)'
            cand --json 'Output in JSON format (for scripting/automation)'
            cand -h 'Print help (see more with ''--help'')'
            cand --help 'Print help (see more with ''--help'')'
            cand -V 'Print version'
            cand --version 'Print version'
