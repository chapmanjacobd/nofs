        &'nofs;rm'= {
            cand -c 'Path to configuration file'
            cand --config 'Path to configuration file'
            cand --policy 'Policy to use for branch selection'
            cand --minfreespace 'Minimum free space required on branch (e.g., "4G", "100M")'
            cand -r 'Remove directories and their contents recursively'
            cand --recursive 'Remove directories and their contents recursively'
            cand -v 'Print each file/directory as it is removed'
            cand --verbose 'Print each file/directory as it is removed'
            cand --json 'Output in JSON format (for scripting/automation)'
            cand -h 'Print help'
            cand --help 'Print help'
            cand -V 'Print version'
            cand --version 'Print version'
        }
        &'nofs;mkdir'= {
            cand -c 'Path to configuration file'
            cand --config 'Path to configuration file'
            cand --paths 'Comma-separated list of branch paths (ad-hoc mode) Format: /path1,/path2 or /path1=RW,/path2=RO'
            cand --policy 'Policy to use for branch selection'
            cand --minfreespace 'Minimum free space required on branch (e.g., "4G", "100M")'
            cand -p 'Create parent directories as needed'
            cand --parents 'Create parent directories as needed'
            cand -v 'Print each directory as it is created'
            cand --verbose 'Print each directory as it is created'
            cand --json 'Output in JSON format (for scripting/automation)'
            cand -h 'Print help'
            cand --help 'Print help'
            cand -V 'Print version'
